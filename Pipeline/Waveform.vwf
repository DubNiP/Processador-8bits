/*<simulation_settings>
<ftestbench_cmd>quartus_eda --gen_testbench --tool=modelsim_oem --format=vhdl --write_settings_files=off Processador8bits -c Processador8bits --vector_source="/home/isabella/intelFPGA_lite/Pipeline/Waveform.vwf" --testbench_file="/home/isabella/intelFPGA_lite/Pipeline/simulation/qsim/Waveform.vwf.vht"</ftestbench_cmd>
<ttestbench_cmd>quartus_eda --gen_testbench --tool=modelsim_oem --format=vhdl --write_settings_files=off Processador8bits -c Processador8bits --vector_source="/home/isabella/intelFPGA_lite/Pipeline/Waveform.vwf" --testbench_file="/home/isabella/intelFPGA_lite/Pipeline/simulation/qsim/Waveform.vwf.vht"</ttestbench_cmd>
<fnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=on --flatten_buses=off --tool=modelsim_oem --format=vhdl --output_directory="/home/isabella/intelFPGA_lite/Pipeline/simulation/qsim/" Processador8bits -c Processador8bits</fnetlist_cmd>
<tnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=off --flatten_buses=off --timescale=1ps --tool=modelsim_oem --format=vhdl --output_directory="/home/isabella/intelFPGA_lite/Pipeline/simulation/qsim/" Processador8bits -c Processador8bits</tnetlist_cmd>
<modelsim_script>onerror {exit -code 1}
vlib work
vcom -work work Processador8bits.vho
vcom -work work Waveform.vwf.vht
vsim -novopt -c -t 1ps -L fiftyfivenm -L altera -L altera_mf -L 220model -L sgate -L altera_lnsim work.Processador8bits_vhd_vec_tst
vcd file -direction Processador8bits.msim.vcd
vcd add -internal Processador8bits_vhd_vec_tst/*
vcd add -internal Processador8bits_vhd_vec_tst/i1/*
proc simTimestamp {} {
    echo "Simulation time: $::now ps"
    if { [string equal running [runStatus]] } {
        after 2500 simTimestamp
    }
}
after 2500 simTimestamp
run -all
quit -f
</modelsim_script>
<modelsim_script_timing>onerror {exit -code 1}
vlib work
vcom -work work Processador8bits.vho
vcom -work work Waveform.vwf.vht
vsim -novopt -c -t 1ps -sdfmax Processador8bits_vhd_vec_tst/i1=Processador8bits_vhd.sdo -L fiftyfivenm -L altera -L altera_mf -L 220model -L sgate -L altera_lnsim work.Processador8bits_vhd_vec_tst
vcd file -direction Processador8bits.msim.vcd
vcd add -internal Processador8bits_vhd_vec_tst/*
vcd add -internal Processador8bits_vhd_vec_tst/i1/*
proc simTimestamp {} {
    echo "Simulation time: $::now ps"
    if { [string equal running [runStatus]] } {
        after 2500 simTimestamp
    }
}
after 2500 simTimestamp
run -all
quit -f
</modelsim_script_timing>
<hdl_lang>vhdl</hdl_lang>
</simulation_settings>*/
